# Site URL (for sitemap, OGP)
NEXT_PUBLIC_SITE_URL=

# Gemini (required for chat and ai_live demos)
# Get API key: https://aistudio.google.com/ → "Get API key"
GOOGLE_GENERATIVE_AI_API_KEY=

# Deepgram (required for voice input)
DEEPGRAM_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 問い合わせメール送信（未接続時は API がログにテンプレを出します）
# RESEND_API_KEY=

# 詳細見積「整理中」画面の動画（任意）… MP4 の直リンク、または YouTube の共有 URL
# NEXT_PUBLIC_ESTIMATE_WAIT_VIDEO_URL=

# Sanity（スクリプトは NEXT_PUBLIC_SANITY_* でも可）
SANITY_PROJECT_ID=
SANITY_DATASET=production
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# シードスクリプト用（書き込みトークン。sanity.io で発行）
SANITY_API_TOKEN=
