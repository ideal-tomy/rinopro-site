# Site URL (for sitemap, OGP)
NEXT_PUBLIC_SITE_URL=

# 実装事例詳細の「実際に触る」用・外部デモ URL（未設定時は /case-studies/{slug}#try-demo へフォールバック）
# NEXT_PUBLIC_SHOWCASE_GEMPO_URL=
# NEXT_PUBLIC_SHOWCASE_SHAKEN_URL=
# NEXT_PUBLIC_SHOWCASE_RECRUIT_URL=
# NEXT_PUBLIC_SHOWCASE_SALES_URL=
# NEXT_PUBLIC_SHOWCASE_SHIFT_URL=

# Gemini (required for chat and ai_live demos)
# Get API key: https://aistudio.google.com/ → "Get API key"
GOOGLE_GENERATIVE_AI_API_KEY=

# Deepgram (required for voice input)
DEEPGRAM_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 問い合わせメール送信（Resend: https://resend.com）
# 本番では必須。未設定の場合、フォームはエラーになります（開発時はサーバーログに下書きを出します）。
# RESEND_API_KEY=re_xxxxxxxx
# 送信元（Resend で検証済みのドメイン。例: AXEON <noreply@axeon.jp>）
# CONTACT_FROM_EMAIL=
# 管理者宛（問い合わせ通知の届き先）
# CONTACT_ADMIN_EMAIL=contact@axeon.jp

# 詳細見積「整理中」画面の動画（任意）… MP4 の直リンク、または YouTube の共有 URL
# NEXT_PUBLIC_ESTIMATE_WAIT_VIDEO_URL=

# Sanity（スクリプトは NEXT_PUBLIC_SANITY_* でも可）
SANITY_PROJECT_ID=
SANITY_DATASET=production
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# シードスクリプト用（書き込みトークン。sanity.io で発行）
SANITY_API_TOKEN=
